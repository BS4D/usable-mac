# ctrl -> cmd
# windows -> ctrl
# alt -> alt

# window navigation
# switching focus
ctrl - left  : yabai -m window --focus west || yabai -m display --focus west
ctrl - right : yabai -m window --focus east || yabai -m display --focus east
ctrl - up    : yabai -m window --focus north
ctrl - down  : yabai -m window --focus south
# resizing windows
ctrl + cmd - left  : yabai -m window --resize left:-10:0
ctrl + cmd - right : yabai -m window --resize right:10:0
ctrl + cmd - up    : yabai -m window --resize top:0:-10
ctrl + cmd - down  : yabai -m window --resize bottom:0:10
# switching windows
ctrl + shift - left  : yabai -m window --swap west || (yabai -m window --display west && yabai -m display --focus west)
ctrl + shift - right : yabai -m window --swap east || (yabai -m window --display east && yabai -m display --focus east)
ctrl + shift - up    : yabai -m window --swap north
ctrl + shift - down  : yabai -m window --swap south

# window state management
ctrl - q : yabai -m window --close
ctrl - w : yabai -m window --toggle zoom-fullscreen
ctrl - e : yabai -m window --toggle float
ctrl - f : yabai -m window --toggle native-fullscreen

# terminal
ctrl - return : kitty --single-instance --working-directory ~

# finder
ctrl - s : open -a finder

# screenshot
ctrl + shift - s : open -a screenshot

# zen tab navigation and manipulation
cmd - pageup [
  "zen" : skhd -k 'ctrl - pageup'
  *       ~
]
cmd - pagedown [
  "zen" : skhd -k 'ctrl - pagedown'
  *       ~
]
cmd + shift - pageup [
  "zen" : skhd -k 'ctrl + shift - pageup'
  *       ~
]
cmd + shift - pagedown [
  "zen" : skhd -k 'ctrl + shift - pagedown'
  *       ~
]

# text navigation and manipulation
cmd - left : skhd -k 'alt - left'
cmd - right : skhd -k 'alt - right'
cmd + shift - left : skhd -k 'alt + shift - left'
cmd + shift - right : skhd -k 'alt + shift - right'
cmd - backspace : skhd -k 'alt - backspace'
