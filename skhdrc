ctrl - q [
  "firefox" : skhd -k 'cmd - q' # exit firefox completely to prevent issues with re-opening tabs
  *       ~
]

# firefox tab navigation and manipulation
cmd - pageup [
  "firefox" : skhd -k 'ctrl - pageup'
  *       ~
]
cmd - pagedown [
  "firefox" : skhd -k 'ctrl - pagedown'
  *       ~
]
cmd + shift - pageup [
  "firefox" : skhd -k 'ctrl + shift - pageup'
  *       ~
]
cmd + shift - pagedown [
  "firefox" : skhd -k 'ctrl + shift - pagedown'
  *       ~
]
# vertical tabs
cmd + alt - z [
  "firefox" : skhd -k 'ctrl - z'
  *       ~
]

# text navigation and manipulation
cmd - left : skhd -k 'alt - left'
cmd - right : skhd -k 'alt - right'
cmd + shift - left : skhd -k 'alt + shift - left'
cmd + shift - right : skhd -k 'alt + shift - right'
cmd - backspace : skhd -k 'alt - backspace'
