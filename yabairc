# window gaps

padding=8

yabai -m config \
  window_gap "$padding" \
  top_padding "$padding" \
  bottom_padding "$padding" \
  left_padding "$padding" \
  right_padding "$padding"

yabai -m config \
  layout bsp \
  auto_balance on \
  window_origin_display focused

yabai -m config mouse_modifier ctrl

# retain focus when spawning a new kitty window on a different display
yabai -m signal --add event=window_created app="^kitty$" action="yabai -m window \$YABAI_WINDOW_ID --focus"
